# Copy this file to .env and fill in your own values.
# .env is gitignored - nothing here is committed.

# --- WorldQuant BRAIN API (required) ---
BRAIN_USERNAME=
BRAIN_PASSWORD=

# --- Storage backend ---
# "supabase" = shared store across accounts; "sqlite" = local file only.
STORAGE_BACKEND=supabase

# Supabase credentials (only needed when STORAGE_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- LLM-guided generation (optional) ---
# Comma-separated API keys; the client rotates across them to spread rate limits.
# Leave blank to disable LLM generation, mutation, and combination.
GEMINI_API_KEYS=
GROQ_API_KEYS=

# --- Competition (optional) ---
# Used by the before/after performance endpoint. Defaults to IQC2026S1 if unset.
IQC_COMPETITION_ID=IQC2026S1

# --- Dataset files (optional) ---
# Paths to the WorldQuant dataset Excel exports. If unset, defaults to
# data/wq_all_datasets.xlsx and data/wq_personal_datasets.xlsx. The bot falls
# back to a built-in minimal field set if neither file exists.
DATASETS_FILE=
PERSONAL_DATASETS_FILE=
